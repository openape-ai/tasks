{
  "name": "openape-tasks-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["app", "cli"],
  "scripts": {
    "dev": "pnpm --filter app dev",
    "build": "pnpm --filter app build",
    "cli:build": "pnpm --filter cli build",
